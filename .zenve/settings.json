{
  "project": "workumi",
  "description": "Workumi is a work orchestration platform that mix humans and AI agents to get the work done.",
  "default_branch": "main",
  "commit_message_prefix": "[zenve]",
  "run_timeout_seconds": 600,
  "run_schedule": "*/10 * * * *",
  "pipeline": {
    "zenve:architect": "zenve:backend-laravel-dev",
    "zenve:code-review": null,
    "zenve:frontend-dev": "zenve:code-review",
    "zenve:backend-laravel-dev": "zenve:frontend-dev",
    "zenve:pm": "zenve:architect"
  },
  "stack": [
    "Laravel",
    "Inertia.js",
    "react",
    "typescript"
  ]
}
