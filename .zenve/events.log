edProjects\n33\t        .filter((p) => {\n34\t            const matchesSearch =\n35\t                p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n36\t                (p.description?.toLowerCase().includes(searchQuery.toLowerCase()) ?? false) ||\n37\t                p.partyName.toLowerCase().includes(searchQuery.toLowerCase());\n38\t\n39\t            const matchesStatus =\n40\t                statusFilter === 'all' ||\n41\t                (statusFilter === 'completed' && p.status === 'completed') ||\n42\t                (statusFilter === 'archived' && p.status === 'archived');\n43\t\n44\t            return matchesSearch && matchesStatus;\n45\t        })\n46\t        .sort((a, b) => {\n47\t            if (sortBy === 'date') {\n48\t                const dateA = a.targetEndDate ? new Date(a.targetEndDate).getTime() : 0;\n49\t                const dateB = b.targetEndDate ? new Date(b.targetEndDate).getTime() : 0;\n50\t                return dateB - dateA; // Most recent first\n51\t            }\n52\t            if (sortBy === 'name') {\n53\t                return a.name.localeCompare(b.name);\n54\t            }\n55\t            if (sortBy === 'hours') {\n56\t                return b.actualHours - a.actualHours;\n57\t            }\n58\t            return 0;\n59\t        });\n60\t\n61\t    // Get work orders and tasks for each project\n62\t    const getProjectStats = (projectId: string) => {\n63\t        const projectWorkOrders = workOrders.filter((wo) => wo.projectId === projectId);\n64\t        const projectTasks = tasks.filter((t) => t.projectId === projectId);\n65\t        return {\n66\t            workOrderCount: projectWorkOrders.length,\n67\t            taskCount: projectTasks.length,\n68\t        };\n69\t    };\n70\t\n71\t    // Calculate summary stats\n72\t    const totalProjects = archivedProjects.length;\n73\t    const completedCount = archivedProjects.filter((p) => p.status === 'completed').length;\n74\t    const archivedCount = archivedProjects.filter((p) => p.status === 'archived').length;\n75\t    const totalHours = archivedProjects.reduce((sum, p) => sum + p.actualHours, 0);\n76\t\n77\t    // Calculate budget performance\n78\t    const projectsWithBudget = archivedProjects.filter((p) => p.budgetHours);\n79\t    const onBudgetCount = projectsWithBudget.filter(\n80\t        (p) => p.budgetHours && p.actualHours <= p.budgetHours\n81\t    ).length;\n82\t    const overBudgetCount = projectsWithBudget.filter(\n83\t        (p) => p.budgetHours && p.actualHours > p.budgetHours\n84\t    ).length;\n85\t\n86\t    const handleRestore = (projectId: string) => {\n87\t        router.post(`/work/projects/${projectId}/restore`);\n88\t    };\n89\t\n90\t    return (\n91\t        <div className=\"space-y-6\">\n92\t            {/* Header Stats */}\n93\t            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n94\t                <div className=\"bg-card border border-border rounded-xl p-4\">\n95\t                    <div className=\"flex items-center gap-3 mb-2\">\n96\t                        <div className=\"p-2 bg-muted rounded-lg\">\n97\t                            <Archive className=\"w-5 h-5 text-muted-foreground\" />\n98\t                        </div>\n99\t                        <div>\n100\t                            <div className=\"text-2xl font-bold text-foreground\">{totalProjects}</div>\n101\t                            <div className=\"text-xs text-muted-foreground\">Total Projects</div>\n102\t                        </div>\n103\t                    </div>\n104\t                    <div className=\"flex items-center gap-3 text-xs\">\n105\t                        <span className=\"text-emerald-600 dark:text-emerald-400\">\n106\t                            {completedCount} completed\n107\t                        </span>\n108\t                        <span className=\"text-muted-foreground\">\u2022</span>\n109\t                        <span className=\"text-muted-foreground\">{archivedCount} archived</span>\n110\t                    </div>\n111\t                </div>\n112\t\n113\t                <div className=\"bg-card border border-border rounded-xl p-4\">\n114\t                    <div className=\"flex items-center gap-3 mb-2\">\n115\t                        <div className=\"p-2 bg-indigo-100 dark:bg-indigo-950/30 rounded-lg\">\n116\t                            <TrendingUp className=\"w-5 h-5 text-indigo-600 dark:text-indigo-400\" />\n117\t                        </div>\n118\t                        <div>\n119\t                            <div className=\"text-2xl font-bold text-foreground\">{totalHours}h</div>\n120\t                            <div className=\"text-xs text-muted-foreground\">Total Hours</div>\n121\t                        </div>\n122\t                    </div>\n123\t                    <div className=\"text-xs text-muted-foreground\">Across all archived projects</div>\n124\t                </div>\n125\t\n126\t                <div className=\"bg-card border border-border rounded-xl p-4\">\n127\t                    <div className=\"flex items-center gap-3 mb-2\">\n128\t                        <div className=\"p-2 bg-emerald-100 dark:bg-emerald-950/30 rounded-lg\">\n129\t                            <TrendingUp className=\"w-5 h-5 text-emerald-600 dark:text-emerald-400\" />\n130\t                        </div>\n131\t                        <div>\n132\t                            <div className=\"text-2xl font-bold text-foreground\">{onBudgetCount}</div>\n133\t                            <div className=\"text-xs text-muted-foreground\">On Budget</div>\n134\t                        </div>\n135\t                    </div>\n136\t                    <div className=\"text-xs text-emerald-600 dark:text-emerald-400\">\n137\t                        At or under estimated hours\n138\t                    </div>\n139\t                </div>\n140\t\n141\t                <div className=\"bg-card border border-border rounded-xl p-4\">\n142\t                    <div className=\"flex items-center gap-3 mb-2\">\n143\t                        <div className=\"p-2 bg-amber-100 dark:bg-amber-950/30 rounded-lg\">\n144\t                            <TrendingDown className=\"w-5 h-5 text-amber-600 dark:text-amber-400\" />\n145\t                        </div>\n146\t                        <div>\n147\t                            <div className=\"text-2xl font-bold text-foreground\">{overBudgetCount}</div>\n148\t                            <div className=\"text-xs text-muted-foreground\">Over Budget</div>\n149\t                        </div>\n150\t                    </div>\n151\t                    <div className=\"text-xs text-amber-600 dark:text-amber-400\">\n152\t                        Exceeded estimated hours\n153\t                    </div>\n154\t                </div>\n155\t            </div>\n156\t\n157\t            {/* Filters and Search */}\n158\t            <div className=\"bg-card border border-border rounded-xl p-4\">\n159\t                <div className=\"flex flex-col sm:flex-row gap-4\">\n160\t                    {/* Search */}\n161\t                    <div className=\"flex-1 relative\">\n162\t                        <Search className=\"absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n163\t                        <Input\n164\t                            type=\"text\"\n165\t                            value={searchQuery}\n166\t                            onChange={(e) => setSearchQuery(e.target.value)}\n167\t                            placeholder=\"Search by project name, description, or client...\"\n168\t                            className=\"pl-10\"\n169\t                        />\n170\t                    </div>\n171\t\n172\t                    {/* Status Filter */}\n173\t                    <div className=\"flex items-center gap-2\">\n174\t                        <Filter className=\"w-4 h-4 text-muted-foreground shrink-0\" />\n175\t                        <Select\n176\t                            value={statusFilter}\n177\t                            onValueChange={(value) =>\n178\t                                setStatusFilter(value as typeof statusFilter)\n179\t                            }\n180\t                        >\n181\t                            <SelectTrigger className=\"w-[140px]\">\n182\t                                <SelectValue />\n183\t                            </SelectTrigger>\n184\t                            <SelectContent>\n185\t                                <SelectItem value=\"all\">All Status</SelectItem>\n186\t                                <SelectItem value=\"completed\">Completed</SelectItem>\n187\t                                <SelectItem value=\"archived\">Archived</SelectItem>\n188\t                            </SelectContent>\n189\t                        </Select>\n190\t                    </div>\n191\t\n192\t                    {/* Sort */}\n193\t                    <div className=\"flex items-center gap-2\">\n194\t                        <ArrowUpDown className=\"w-4 h-4 text-muted-foreground shrink-0\" />\n195\t                        <Select\n196\t                            value={sortBy}\n197\t                            onValueChange={(value) => setSortBy(value as typeof sortBy)}\n198\t                        >\n199\t                            <SelectTrigger className=\"w-[140px]\">\n200\t                                <SelectValue />\n201\t                            </SelectTrigger>\n202\t                            <SelectContent>\n203\t                                <SelectItem value=\"date\">Sort by Date</SelectItem>\n204\t                                <SelectItem value=\"name\">Sort by Name</SelectItem>\n205\t                                <SelectItem value=\"hours\">Sort by Hours</SelectItem>\n206\t                            </SelectContent>\n207\t                        </Select>\n208\t                    </div>\n209\t                </div>\n210\t            </div>\n211\t\n212\t            {/* Project Cards */}\n213\t            {filteredProjects.length === 0 ? (\n214\t                <div className=\"bg-card border border-border rounded-xl p-12 text-center\">\n215\t                    <div className=\"w-16 h-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4\">\n216\t                        <Archive className=\"w-8 h-8 text-muted-foreground\" />\n217\t                    </div>\n218\t                    <h3 className=\"text-lg font-semibold text-foreground mb-2\">\n219\t                        {searchQuery ? 'No projects found' : 'No archived projects'}\n220\t                    </h3>\n221\t                    <p className=\"text-sm text-muted-foreground\">\n222\t                        {searchQuery\n223\t                            ? 'Try adjusting your search or filters'\n224\t                            : 'Completed and archived projects will appear here'}\n225\t                    </p>\n226\t                </div>\n227\t            ) : (\n228\t                <>\n229\t                    <div className=\"flex items-center justify-between mb-2\">\n230\t                        <p className=\"text-sm text-muted-foreground\">\n231\t                            Showing {filteredProjects.length} of {totalProjects} projects\n232\t                        </p>\n233\t                    </div>\n234\t\n235\t                    <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n236\t                        {filteredProjects.map((project) => {\n237\t                            const stats = getProjectStats(project.id);\n238\t                            return (\n239\t                                <ArchiveProjectCard\n240\t                                    key={project.id}\n241\t                                    project={project}\n242\t                                    workOrderCount={stats.workOrderCount}\n243\t                                    taskCount={stats.taskCount}\n244\t                                    onRestore={() => handleRestore(project.id)}\n245\t                                />\n246\t                            );\n247\t                        })}\n248\t                    </div>\n249\t                </>\n250\t            )}\n251\t        </div>\n252\t    );\n253\t}\n254\t"}}
