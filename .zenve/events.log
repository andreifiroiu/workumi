     const prevMonthLastDay = new Date(year, month, 0).getDate();\n33\t        for (let i = startingDayOfWeek - 1; i >= 0; i--) {\n34\t            calendarDays.push({\n35\t                date: new Date(year, month - 1, prevMonthLastDay - i),\n36\t                isCurrentMonth: false,\n37\t                dayNumber: prevMonthLastDay - i,\n38\t            });\n39\t        }\n40\t    }\n41\t\n42\t    // Current month days\n43\t    for (let day = 1; day <= daysInMonth; day++) {\n44\t        calendarDays.push({\n45\t            date: new Date(year, month, day),\n46\t            isCurrentMonth: true,\n47\t            dayNumber: day,\n48\t        });\n49\t    }\n50\t\n51\t    // Next month overflow days to fill grid\n52\t    const remainingDays = 42 - calendarDays.length; // 6 rows \u00d7 7 days\n53\t    for (let day = 1; day <= remainingDays; day++) {\n54\t        calendarDays.push({\n55\t            date: new Date(year, month + 1, day),\n56\t            isCurrentMonth: false,\n57\t            dayNumber: day,\n58\t        });\n59\t    }\n60\t\n61\t    // Get items for a specific date\n62\t    const getItemsForDate = (date: Date) => {\n63\t        const dateStr = date.toISOString().split('T')[0];\n64\t\n65\t        const projectsOnDate = projects.filter((p) => {\n66\t            if (!p.targetEndDate) return false;\n67\t            return p.targetEndDate.startsWith(dateStr);\n68\t        });\n69\t\n70\t        const workOrdersOnDate = workOrders.filter((wo) => {\n71\t            return wo.dueDate?.startsWith(dateStr);\n72\t        });\n73\t\n74\t        return { projects: projectsOnDate, workOrders: workOrdersOnDate };\n75\t    };\n76\t\n77\t    // Navigation\n78\t    const goToPreviousMonth = () => {\n79\t        setCurrentDate(new Date(year, month - 1, 1));\n80\t    };\n81\t\n82\t    const goToNextMonth = () => {\n83\t        setCurrentDate(new Date(year, month + 1, 1));\n84\t    };\n85\t\n86\t    const goToToday = () => {\n87\t        setCurrentDate(new Date());\n88\t    };\n89\t\n90\t    const monthName = currentDate.toLocaleString('default', { month: 'long', year: 'numeric' });\n91\t\n92\t    // Check if date is today\n93\t    const isToday = (date: Date) => {\n94\t        const today = new Date();\n95\t        return (\n96\t            date.getDate() === today.getDate() &&\n97\t            date.getMonth() === today.getMonth() &&\n98\t            date.getFullYear() === today.getFullYear()\n99\t        );\n100\t    };\n101\t\n102\t    // Stats\n103\t    const totalItems = projects.length + workOrders.length;\n104\t    const overdueItems = [\n105\t        ...projects.filter((p) => p.targetEndDate && new Date(p.targetEndDate) < new Date()),\n106\t        ...workOrders.filter((wo) => wo.dueDate && new Date(wo.dueDate) < new Date()),\n107\t    ].length;\n108\t\n109\t    return (\n110\t        <div className=\"space-y-6\">\n111\t            {/* Header */}\n112\t            <div className=\"flex items-center justify-between\">\n113\t                <div className=\"flex items-center gap-4\">\n114\t                    <h2 className=\"text-2xl font-bold text-foreground\">{monthName}</h2>\n115\t                    <Button variant=\"ghost\" size=\"sm\" onClick={goToToday}>\n116\t                        Today\n117\t                    </Button>\n118\t                </div>\n119\t\n120\t                <div className=\"flex items-center gap-2\">\n121\t                    <div className=\"flex items-center gap-1 px-3 py-1.5 bg-card border border-border rounded-lg text-sm\">\n122\t                        <CalendarIcon className=\"w-4 h-4 text-muted-foreground\" />\n123\t                        <span className=\"font-medium text-foreground\">{totalItems}</span>\n124\t                        <span className=\"text-muted-foreground\">items</span>\n125\t                        {overdueItems > 0 && (\n126\t                            <>\n127\t                                <span className=\"mx-1 text-border\">\u2022</span>\n128\t                 