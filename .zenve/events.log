s' => [],\n40\t                'currentView' => 'all_projects',\n41\t                'currentUserId' => (string) $user->id,\n42\t            ]);\n43\t        }\n44\t\n45\t        $currentView = UserPreference::get($user, 'work_view', 'all_projects');\n46\t\n47\t        $props = [\n48\t            'projects' => $this->getProjects($team, $user),\n49\t            'workOrders' => $this->getWorkOrders($team),\n50\t            'tasks' => $this->getTasks($team),\n51\t            'deliverables' => $this->getDeliverables($team),\n52\t            'parties' => $this->getParties($team),\n53\t            'teamMembers' => $this->getTeamMembers($team),\n54\t            'communicationThreads' => $this->getCommunicationThreads($team),\n55\t            'currentView' => $currentView,\n56\t            'currentUserId' => (string) $user->id,\n57\t        ];\n58\t\n59\t        if ($currentView === 'my_work') {\n60\t            $showInformed = UserPreference::get($user, 'my_work_show_informed', 'false') === 'true';\n61\t            $props['myWorkData'] = $this->getMyWorkData($user, $team, $showInformed);\n62\t            $props['myWorkMetrics'] = $this->getMyWorkMetrics($user, $team);\n63\t            $props['myWorkSubtab'] = UserPreference::get($user, 'my_work_subtab', 'tasks');\n64\t            $props['myWorkShowInformed'] = $showInformed;\n65\t        }\n66\t\n67\t        return Inertia::render('work/index', $props);\n68\t    }\n69\t\n70\t    public function updatePreference(Request $request)\n71\t    {\n72\t        $request->validate([\n73\t            'key' => 'required|string',\n74\t            'value' => 'nullable|string',\n75\t        ]);\n76\t\n77\t        $allowedKeys = [\n78\t            'work_view',\n79\t            'my_work_subtab',\n80\t            'my_work_show_informed',\n81\t        ];\n82\t\n83\t        $key = $request->input('key');\n84\t\n85\t        if (! in_array($key, $allowedKeys, true)) {\n86\t            return back()->withErrors(['key' => 'Invalid preference key.']);\n87\t        }\n88\t\n89\t        UserPreference::set($request->user(), $key, $request->value);\n90\t\n91\t        return back();\n92\t    }\n93\t\n94\t    /**\n95\t     * Get My Work data for the given user and team.\n96\t     *\n97\t     * @return array{projects: array, workOrders: array, tasks: array}\n98\t     */\n99\t    private function getMyWorkData(User $user, Team $team, bool $showInformed = false): array\n100\t    {\n101\t        return [\n102\t            'projects' => $this->getMyWorkProjects($user, $team, $showInformed),\n103\t            'workOrders' => $this->getMyWorkWorkOrders($user, $team, $showInformed),\n104\t            'tasks' => $this->getMyWorkTasks($user, $team),\n105\t        ];\n106\t    }\n107\t\n108\t    /**\n109\t     * Get My Work metrics for the given user and team.\n110\t     *\n111\t     * @return array{accountableCount: int, responsibleCount: int, awaitingReviewCount: int, assignedTasksCount: int}\n112\t     */\n113\t    private function getMyWorkMetrics(User $user, Team $team): array\n114\t    {\n115\t        $accountableProjectsCount = Project::forTeam($team->id)\n116\t            ->whereUserIsAccountable($user->id)\n117\t            ->count();\n118\t\n119\t        $accountableWorkOrdersCount = WorkOrder::forTeam($team->id)\n120\t            ->whereUserIsAccountable($user->id)\n121\t            ->count();\n122\t\n123\t        $responsibleProjectsCount = Project::forTeam($team->id)\n124\t            ->whereUserIsResponsible($user->id)\n125\t            ->count();\n126\t\n127\t        $responsibleWorkOrdersCount = WorkOrder::forTeam($team->id)\n128\t            ->whereUserIsResponsible($user->id)\n129\t            ->count();\n130\t\n131\t        $awaitingReviewCount = WorkOrder::forTeam($team->id)\n132\t            ->inReviewWhereUserIsAccountable($user->id)\n133\t            ->count();\n134\t\n135\t        $assignedTasksCount = Task::forTeam($team->id)\n136\t            ->assignedTo($user->id)\n137\t            ->whereNotIn('status', [TaskStatus::Done, TaskStatus::Cancelled])\n138\t            ->count();\n139\t\n140\t        return [\n141\t            'accountableCount' => $accountableProjectsCount + $accountableWorkOrdersCount,\n142\t            'responsibleCount' => $responsibleProjectsCount + $responsibleWorkOrdersCount,\n143\t            'awaitingReviewCount' => $awaitingReviewCount,\n144\t            'assignedTasksCount' => $assignedTasksCount,\n145\t        ];\n146\t    }\n147\t\n148\t    /**\n149\t     * Get projects where the user has a RACI role.\n150\t     */\n151\t    private function getMyWorkProjects(User $user, Team $team, bool $showInformed): array\n152\t    {\n153\t        return Project::forTeam($team->id)\n154\t            ->whereUserHasRaciRole($user->id, excludeInformed: ! $showInformed)\n155\t            ->whereNotIn('status', [ProjectStatus::Completed, ProjectStatus::Archived])\n156\t            ->with(['party', 'owner'])\n157\t            ->orderBy('updated_at', 'desc')\n158\t            ->get()\n159\t            ->map(fn (Project $project) => [\n160\t                'id' => (string) $project->id,\n161\t                'name' => $project->name,\n162\t                'description' => $project->description,\n163\t                'partyId' => (string) $project->party_id,\n164\t                'partyName' => $project->party?->name ?? 'Unknown',\n165\t                'ownerId' => (string) $project->owner_id,\n166\t                'ownerName' => $project->owner?->name ?? 'Unknown',\n167\t                'status' => $project->status->value,\n168\t                'startDate' => $project->start_date->format('Y-m-d'),\n169\t                'targetEndDate' => $project->target_end_date?->format('Y-m-d'),\n170\t                'budgetHours' => (float) $project->budget_hours,\n171\t                'actualHours' => (float) $project->actual_hours,\n172\t                'progress' => $project->progress,\n173\t                'tags' => $project->tags ?? [],\n174\t                'isPrivate' => $project->is_private,\n175\t                'userRaciRoles' => $project->getUserRaciRoles($user->id),\n176\t            ])\n177\t            ->all();\n178\t    }\n179\t\n180\t    /**\n181\t     * Get work orders where the user has a RACI role.\n182\t     */\n183\t    private function getMyWorkWorkOrders(User $user, Team $team, bool $showInformed): array\n184\t    {\n185\t        return WorkOrder::forTeam($team->id)\n186\t            ->whereUserHasRaciRole($user->id, excludeInformed: ! $showInformed)\n187\t            ->whereNotIn('status', [WorkOrderStatus::Delivered, WorkOrderStatus::Cancelled])\n188\t            ->with(['project', 'assignedTo', 'createdBy'])\n189\t            ->orderBy('due_date')\n190\t            ->get()\n191\t            ->map(fn (WorkOrder $wo) => [\n192\t                'id' => (string) $wo->id,\n193\t                'title' => $wo->title,\n194\t                'description' => $wo->description,\n195\t                'projectId' => (string) $wo->project_id,\n196\t                'projectName' => $wo->project?->name ?? 'Unknown',\n197\t                'assignedToId' => $wo->assigned_to_id ? (string) $wo->assigned_to_id : null,\n198\t                'assignedToName' => $wo->assignedTo?->name ?? 'Unassigned',\n199\t                'status' => $wo->status->value,\n200\t                'priority' => $wo->priority->value,\n201\t                'dueDate' => $wo->due_date?->format('Y-m-d'),\n202\t                'estimatedHours' => (float) $wo->estimated_hours,\n203\t                'actualHours' => (float) $wo->actual_hours,\n204\t                'acceptanceCriteria' => $wo->acceptance_criteria ?? [],\n205\t                'sopAttached' => $wo->sop_attached,\n206\t                'sopName' => $wo->sop_name,\n207\t                'partyContactId' => $wo->party_contact_id ? (string) $wo->party_contact_id : null,\n208\t                'createdBy' => (string) $wo->created_by_id,\n209\t                'createdByName' => $wo->createdBy?->name ?? 'Unknown',\n210\t                'userRaciRoles' => $wo->getUserRaciRoles($user->id),\n211\t            ])\n212\t            ->all();\n213\t    }\n214\t\n215\t    /**\n216\t     * Get tasks assigned to the user.\n217\t     */\n218\t    private function getMyWorkTasks(User $user, Team $team): array\n219\t    {\n220\t        return Task::forTeam($team->id)\n221\t            ->assignedTo($user->id)\n222\t            ->whereNotIn('status', [TaskStatus::Done, TaskStatus::Cancelled, TaskStatus::Archived])\n223\t            ->with(['workOrder', 'project', 'assignedTo'])\n224\t            ->orderBy('due_date')\n225\t            ->get()\n226\t            ->map(fn (Task $task) => [\n227\t                'id' => (string) $task->id,\n228\t                'title' => $task->title,\n229\t                'description' => $task->description,\n230\t                'workOrderId' => (string) $task->work_order_id,\n231\t                'workOrderTitle' => $task->workOrder?->title ?? 'Unknown',\n232\t                'projectId' => (string) $task->project_id,\n233\t                'projectName' => $task->project?->name ?? 'Unknown',\n234\t                'assignedToId' => $task->assigned_to_id ? (string) $task->assigned_to_id : null,\n235\t                'assignedToName' => $task->assignedTo?->name ?? 'Unassigned',\n236\t                'status' => $task->status->value,\n237\t                'dueDate' => $task->due_date?->format('Y-m-d'),\n238\t                'estimatedHours' => (float) $task->estimated_hours,\n239\t                'actualHours' => (float) $task->actual_hours,\n240\t                'checklistItems' => $task->checklist_items ?? [],\n241\t                'dependencies' => $task->dependencies ?? [],\n242\t                'isBlocked' => $task->is_blocked,\n243\t            ])\n244\t            ->all();\n245\t    }\n246\t\n247\t    private function getProjects(Team $team, User $user): array\n248\t    {\n249\t        return Project::forTeam($team->id)\n250\t            ->visibleTo($user->id)\n251\t            ->with([\n252\t                'party',\n253\t                'owner',\n254\t                'workOrderLists.workOrders.tasks',\n255\t                'workOrderLists.workOrders.assignedTo',\n256\t            ])\n257\t            ->orderBy('updated_at', 'desc')\n258\t            ->get()\n259\t            ->map(fn (Project $project) => [\n260\t                'id' => (string) $project->id,\n261\t                'name' => $project->name,\n262\t                'description' => $project->description,\n263\t                'partyId' => (string) $project->party_id,\n264\t                'partyName' => $project->party?->name ?? 'Unknown',\n265\t                'ownerId' => (string) $project->owner_id,\n266\t                'ownerName' => $project->owner?->name ?? 'Unknown',\n267\t                'status' => $project->status->value,\n268\t                'startDate' => $project->start_date->format('Y-m-d'),\n269\t                'targetEndDate' => $project->target_end_date?->format('Y-m-d'),\n270\t                'budgetHours' => (float) $project->budget_hours,\n271\t                'actualHours' => (float) $project->actual_hours,\n272\t                'progress' => $project->progress,\n273\t                'tags' => $project->tags ?? [],\n274\t                'isPrivate' => $project->is_private,\n275\t                'workOrderLists' => $project->workOrderLists->map(fn ($list) => [\n276\t                    'id' => (string) $list->id,\n277\t                    'name' => $list->name,\n278\t                    'color' => $list->color,\n279\t                    'position' => $list->position,\n280\t                    'workOrders' => $list->workOrders->map(fn ($wo) => [\n281\t                        'id' => (string) $wo->id,\n282\t                        'title' => $wo->title,\n283\t                        'status' => $wo->status->value,\n284\t                        'priority' => $wo->priority->value,\n285\t                        'dueDate' => $wo->due_date?->format('Y-m-d'),\n286\t                        'assignedToName' => $wo->assignedTo?->name ?? 'Unassigned',\n287\t                        'tasksCount' => $wo->tasks->count(),\n288\t                        'completedTasksCount' => $wo->tasks->where('status', 'done')->count(),\n289\t                        'positionInList' => $wo->position_in_list,\n290\t                    ])->all(),\n291\t                ])->all(),\n292\t                'ungroupedWorkOrders' => $project->ungroupedWorkOrders()\n293\t                    ->with(['tasks', 'assignedTo'])\n294\t                    ->get()\n295\t                    ->map(fn ($wo) => [\n296\t                        'id' => (string) $wo->id,\n297\t                        'title' => $wo->title,\n298\t                        'status' => $wo->status->value,\n299\t                        'priority' => $wo->priority->value,\n300\t                        'dueDate' => $wo->due_date?->format('Y-m-d'),\n301\t                        'assignedToName' => $wo->assignedTo?->name ?? 'Unassigned',\n302\t                        'tasksCount' => $wo->tasks->count(),\n303\t                        'completedTasksCount' => $wo->tasks->where('status', 'done')->count(),\n304\t                        'positionInList' => $wo->position_in_list,\n305\t                    ])->all(),\n306\t            ])\n307\t            ->all();\n308\t    }\n309\t\n310\t    private function getWorkOrders(Team $team): array\n311\t    {\n312\t        return WorkOrder::forTeam($team->id)\n313\t            ->with(['project', 'assignedTo', 'createdBy', 'workOrderList', 'tasks'])\n314\t            ->orderBy('due_date')\n315\t            ->get()\n316\t            ->map(fn (WorkOrder $wo) => [\n317\t                'id' => (string) $wo->id,\n318\t                'title' => $wo->title,\n319\t                'description' => $wo->description,\n320\t                'projectId' => (string) $wo->project_id,\n321\t                'projectName' => $wo->project?->name ?? 'Unknown',\n322\t                'assignedToId' => $wo->assigned_to_id ? (string) $wo->assigned_to_id : null,\n323\t                'assignedToName' => $wo->assignedTo?->name ?? 'Unassigned',\n324\t                'status' => $wo->status->value,\n325\t                'priority' => $wo->priority->value,\n326\t                'dueDate' => $wo->due_date?->format('Y-m-d'),\n327\t                'estimatedHours' => (float) $wo->estimated_hours,\n328\t                'actualHours' => (float) $wo->actual_hours,\n329\t                'acceptanceCriteria' => $wo->acceptance_criteria ?? [],\n330\t                'sopAttached' => $wo->sop_attached,\n331\t                'sopName' => $wo->sop_name,\n332\t                'partyContactId' => $wo->party_contact_id ? (string) $wo->party_contact_id : null,\n333\t                'createdBy' => (string) $wo->created_by_id,\n334\t                'createdByName' => $wo->createdBy?->name ?? 'Unknown',\n335\t                'workOrderListId' => $wo->work_order_list_id ? (string) $wo->work_order_list_id : null,\n336\t                'workOrderListName' => $wo->workOrderList?->name,\n337\t                'tasksCount' => $wo->tasks->count(),\n338\t                'completedTasksCount' => $wo->tasks->where('status', 'done')->count(),\n339\t            ])\n340\t            ->all();\n341\t    }\n342\t\n343\t    private function getTasks(Team $team): array\n344\t    {\n345\t        return Task::forTeam($team->id)\n346\t            ->with(['workOrder', 'project', 'assignedTo'])\n347\t            ->orderBy('due_date')\n348\t            ->get()\n349\t            ->map(fn (Task $task) => [\n350\t                'id' => (string) $task->id,\n351\t                'title' => $task->title,\n352\t                'description' => $task->description,\n353\t                'workOrderId' => (string) $task->work_order_id,\n354\t                'workOrderTitle' => $task->workOrder?->title ?? 'Unknown',\n355\t                'projectId' => (string) $task->project_id,\n356\t                'projectName' => $task->project?->name ?? 'Unknown',\n357\t                'assignedToId' => $task->assigned_to_id ? (string) $task->assigned_to_id : null,\n358\t                'assignedToName' => $task->assignedTo?->name ?? 'Unassigned',\n359\t                'status' => $task->status->value,\n360\t                'dueDate' => $task->due_date?->format('Y-m-d'),\n361\t                'estimatedHours' => (float) $task->estimated_hours,\n362\t                'actualHours' => (float) $task->actual_hours,\n363\t                'checklistItems' => $task->checklist_items ?? [],\n364\t                'dependencies' => $task->dependencies ?? [],\n365\t                'isBlocked' => $task->is_blocked,\n366\t            ])\n367\t            ->all();\n368\t    }\n369\t\n370\t    private function getDeliverables(Team $team): array\n371\t    {\n372\t        return Deliverable::forTeam($team->id)\n373\t            ->with(['workOrder', 'project'])\n374\t            ->orderBy('created_date', 'desc')\n375\t            ->get()\n376\t            ->map(fn (Deliverable $del) => [\n377\t                'id' => (string) $del->id,\n378\t                'title' => $del->title,\n379\t                'description' => $del->description,\n380\t                'workOrderId' => (string) $del->work_order_id,\n381\t                'workOrderTitle' => $del->workOrder?->title ?? 'Unknown',\n382\t                'projectId' => (string) $del->project_id,\n383\t                'type' => $del->type->value,\n384\t                'status' => $del->status->value,\n385\t                'version' => $del->version,\n386\t                'createdDate' => $del->created_date->format('Y-m-d'),\n387\t                'deliveredDate' => $del->delivered_date?->format('Y-m-d'),\n388\t                'fileUrl' => $del->file_url,\n389\t                'acceptanceCriteria' => $del->acceptance_criteria ?? [],\n390\t            ])\n391\t            ->all();\n392\t    }\n393\t\n394\t    private function getParties(Team $team): array\n395\t    {\n396\t        return Party::forTeam($team->id)\n397\t            ->orderBy('name')\n398\t            ->get()\n399\t            ->map(fn (Party $party) => [\n400\t                'id' => (string) $party->id,\n401\t                'name' => $party->name,\n402\t                'type' => $party->type->value,\n403\t                'contactName' => $party->contact_name,\n404\t                'contactEmail' => $party->contact_email,\n405\t            ])\n406\t            ->all();\n407\t    }\n408\t\n409\t    private function getTeamMembers(Team $team): array\n410\t    {\n411\t        return $team->users()\n412\t            ->get()\n413\t            ->map(fn (User $user) => [\n414\t                'id' => (string) $user->id,\n415\t                'name' => $user->name,\n416\t                'type' => 'human',\n417\t                'role' => 'Team Member',\n418\t                'avatarUrl' => $user->avatar,\n419\t                'skills' => [],\n420\t            ])\n421\t            ->all();\n422\t    }\n423\t\n424\t    private function getCommunicationThreads(Team $team): array\n425\t    {\n426\t        return CommunicationThread::forTeam($team->id)\n427\t            ->with('threadable')\n428\t            ->orderBy('last_activity', 'desc')\n429\t            ->get()\n430\t            ->map(fn (CommunicationThread $thread) => [\n431\t                'id' => (string) $thread->id,\n432\t                'workItemType' => $thread->threadable_type === Project::class ? 'project' : 'workOrder',\n433\t                'workItemId' => (string) $thread->threadable_id,\n434\t                'workItemTitle' => $thread->threadable?->name ?? $thread->threadable?->title ?? 'Unknown',\n435\t                'messageCount' => $thread->message_count,\n436\t                'lastActivity' => $thread->last_activity?->toIso8601String(),\n437\t            ])\n438\t            ->all();\n439\t    }\n440\t}\n441\t"}}
