n39\texport default function Work({\n40\t    projects,\n41\t    workOrders,\n42\t    tasks,\n43\t    deliverables,\n44\t    parties,\n45\t    teamMembers,\n46\t    communicationThreads,\n47\t    currentView,\n48\t    currentUserId,\n49\t    myWorkData,\n50\t    myWorkMetrics,\n51\t    myWorkSubtab,\n52\t    myWorkShowInformed,\n53\t}: WorkPageProps) {\n54\t    const [view, setView] = useState<WorkView>(currentView);\n55\t    const [searchQuery, setSearchQuery] = useState('');\n56\t    const [createProjectDialogOpen, setCreateProjectDialogOpen] = useState(false);\n57\t    const [createWorkOrderDialogOpen, setCreateWorkOrderDialogOpen] = useState(false);\n58\t    const [selectedProjectId, setSelectedProjectId] = useState<string | null>(null);\n59\t    const [createTaskDialogOpen, setCreateTaskDialogOpen] = useState(false);\n60\t    const [selectedWorkOrderId, setSelectedWorkOrderId] = useState<string | null>(null);\n61\t\n62\t    const projectForm = useForm({\n63\t        name: '',\n64\t        partyId: '',\n65\t        startDate: new Date().toISOString().split('T')[0],\n66\t        description: '',\n67\t        isPrivate: false,\n68\t    });\n69\t\n70\t    const workOrderForm = useForm({\n71\t        title: '',\n72\t        projectId: '',\n73\t        description: '',\n74\t        priority: 'medium' as const,\n75\t        dueDate: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0], // 1 week from now\n76\t    });\n77\t\n78\t    const taskForm = useForm({\n79\t        title: '',\n80\t        workOrderId: '',\n81\t        description: '',\n82\t        dueDate: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0], // 1 week from now\n83\t    });\n84\t\n85\t    const handleViewChange = (newView: WorkView) => {\n86\t        setView(newView);\n87\t        router.patch('/work/preferences', { key: 'work_view', value: newView }, { preserveState: true });\n88\t    };\n89\t\n90\t    const handleQuickAdd = (data: QuickAddData) => {\n91\t        if (data.type === 'project') {\n92\t            projectForm.setData('name', data.title);\n93\t            setCreateProjectDialogOpen(true);\n94\t        }\n95\t    };\n96\t\n97\t    const handleCreateWorkOrder = (projectId: string) => {\n98\t        setSelectedProjectId(projectId);\n99\t        workOrderForm.setData('projectId', projectId);\n100\t        setCreateWorkOrderDialogOpen(true);\n101\t    };\n102\t\n103\t    const handleCreateTask = (workOrderId: string) => {\n104\t        setSelectedWorkOrderId(workOrderId);\n105\t        taskForm.setData('workOrderId', workOrderId);\n106\t        setCreateTaskDialogOpen(true);\n107\t    };\n108\t\n109\t    const handleCreateWorkOrderFromKanban = (status: string) => {\n110\t        workOrderForm.reset();\n111\t        setCreateWorkOrderDialogOpen(true);\n112\t    };\n113\t\n114\t    const handleCreateProject = (e: React.FormEvent) => {\n115\t        e.preventDefault();\n116\t        projectForm.post('/work/projects', {\n117\t            preserveScroll: true,\n118\t            onSuccess: () => {\n119\t                projectForm.reset();\n120\t                setCreateProjectDialogOpen(false);\n121\t            },\n122\t        });\n123\t    };\n124\t\n125\t    const handleSubmitWorkOrder = (e: React.FormEvent) => {\n126\t        e.preventDefault();\n127\t        workOrderForm.post('/work/work-orders', {\n128\t            preserveScroll: true,\n129\t            onSuccess: () => {\n130\t                workOrderForm.reset();\n131\t                setCreateWorkOrderDialogOpen(false);\n132\t                setSelectedProjectId(null);\n133\t            },\n134\t        });\n135\t    };\n136\t\n137\t    const handleSubmitTask = (e: React.FormEvent) => {\n138\t        e.preventDefault();\n139\t        taskForm.post('/work/tasks', {\n140\t            preserveScroll: true,\n141\t            onSuccess: () => {\n142\t                taskForm.reset();\n143\t                setCreateTaskDialogOpen(false);\n144\t                setSelectedWorkOrderId(null);\n145\t            },\n146\t        });\n147\t    };\n148\t\n149\t    // Filter projects based on search\n150\t    const filteredProjects = searchQuery\n151\t        ? projects.filter(\n152\t              (p) =>\n153\t                  p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n154\t                  (p.description?.toLowerCase().includes(searchQuery.toLowerCase()) ?? false)\n155\t          )\n156\t        : projects;\n157\t\n158\t    const activeProjects = filteredProjects.filter((p) => p.status === 'active' || p.status === 'on_hold');\n159\t\n160\t    return (\n161\t        <AppLayout breadcrumbs={breadcrumbs}>\n162\t            <Head title=\"Work\" />\n163\t\n164\t            <div className=\"flex h-full flex-1 flex-col\">\n165\t                {/* Header */}\n166\t                <div className=\"px-6 py-6 border-b border-sidebar-border/70 dark:border-sidebar-border\">\n167\t                    <h1 className=\"text-2xl font-bold text-foreground mb-2\">Work</h1>\n168\t                    <p className=\"text-muted-foreground\">\n169\t                        Manage projects, work orders, tasks, and deliverables\n170\t                    </p>\n171\t                </div>\n172\t\n173\t                {/* View Tabs */}\n174\t                <ViewTabs currentView={view} onViewChange={handleViewChange} />\n175\t\n176\t                {/* Main Content */}\n177\t                <div className=\"flex-1 overflow-auto\">\n178\t                    {/* Search Bar (for relevant views) */}\n179\t                    {view === 'all_projects' && (\n180\t                        <div className=\"p-6 pb-0\">\n181\t                            <div className=\"mb-6 flex items-center gap-4\">\n182\t                                <div className=\"flex-1 relative\">\n183\t                                    <Search className=\"absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n184\t                                    <Input\n185\t                                        type=\"text\"\n186\t                                        value={searchQuery}\n187\t                                        onChange={(e) => setSearchQuery(e.target.value)}\n188\t                                        placeholder=\"Search projects, work orders, tasks...\"\n189\t                                        className=\"pl-10\"\n190\t                                    />\n191\t                                </div>\n192\t                            </div>\n193\t                        </div>\n194\t                    )}\n195\t\n196\t                    {/* All Projects View */}\n197\t                    {view === 'all_projects' && (\n198\t                        <div className=\"px-6 pb-6\">\n199\t                            <div className=\"bg-card border border-border rounded-xl overflow-hidden\">\n200\t                                <QuickAddBar onQuickAdd={handleQuickAdd} />\n201\t\n202\t                                <div className=\"divide-y divide-border\">\n203\t                                    {activeProjects.length === 0 ? (\n204\t                                        <div className=\"p-12 text-center\">\n205\t                                            <div className=\"w-16 h-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4\">\n206\t                                                <Search className=\"w-8 h-8 text-muted-foreground\" />\n207\t                                            </div>\n208\t                                            <h3 className=\"text-lg font-semibold text-foreground mb-2\">\n209\t                                                {searchQuery ? 'No projects found' : 'No active projects'}\n210\t                                            </h3>\n211\t                                            <p className=\"text-sm text-muted-foreground mb-6\">\n212\t                                                {searchQuery\n213\t                                                    ? 'Try adjusting your search query'\n214\t                                                    : 'Get started by creating your first project'}\n215\t                                            </p>\n216\t                                            {!searchQuery && (\n217\t                                                <Button onClick={() => setCreateProjectDialogOpen(true)}>\n218\t                                                    Create First Project\n219\t                                                </Button>\n220\t                                            )}\n221\t                                        </div>\n222\t                                    ) : (\n223\t                                        activeProjects.map((project) => (\n224\t                                            <ProjectTreeItem\n225\t                                                key={project.id}\n226\t                                                project={project}\n227\t                                                workOrders={workOrders}\n228\t                                                tasks={tasks}\n229\t                                                onCreateWorkOrder={handleCreateWorkOrder}\n230\t                                                onCreateTask={handleCreateTask}\n231\t                                            />\n232\t                                        ))\n233\t                                    )}\n234\t                                </div>\n235\t                            </div>\n236\t                        </div>\n237\t                    )}\n238\t\n239\t                    {/* My Work View */}\n240\t                    {view === 'my_work' && (\n241\t                        <MyWorkView\n242\t                            workOrders={workOrders}\n243\t                            tasks={tasks}\n244\t                            currentUserId={currentUserId}\n245\t                            myWorkData={myWorkData}\n246\t                            myWorkMetrics={myWorkMetrics}\n247\t                            myWorkSubtab={myWorkSubtab}\n248\t                            myWorkShowInformed={myWorkShowInformed}\n249\t                        />\n250\t                    )}\n251\t\n252\t                    {/* By Status (Kanban) View */}\n253\t                    {view === 'by_status' && (\n254\t                        <div className=\"p-6\">\n255\t                            <KanbanView\n256\t                                workOrders={workOrders}\n257\t                                tasks={tasks}\n258\t                                onCreateWorkOrder={handleCreateWorkOrderFromKanban}\n259\t                            />\n260\t                        </div>\n261\t                    )}\n262\t\n263\t                    {/* Calendar View */}\n264\t                    {view === 'calendar' && (\n265\t                        <div className=\"p-6\">\n266\t                            <CalendarView projects={projects} workOrders={workOrders} />\n267\t                        </div>\n268\t                    )}\n269\t\n270\t                    {/* Archive View */}\n271\t                    {view === 'archive' && (\n272\t                        <div className=\"p-6\">\n273\t                            <ArchiveView projects={projects} workOrders={workOrders} tasks={tasks} />\n274\t                        </div>\n275\t                    )}\n276\t                </div>\n277\t            </div>\n278\t\n279\t            {/* Create Project Dialog */}\n280\t            <Dialog open={createProjectDialogOpen} onOpenChange={setCreateProjectDialogOpen}>\n281\t                <DialogContent>\n282\t                    <form onSubmit={handleCreateProject}>\n283\t                        <DialogHeader>\n284\t                            <DialogTitle>Create New Project</DialogTitle>\n285\t                            <DialogDescription>\n286\t                                Create a new project to organize your work orders and tasks.\n287\t                            </DialogDescription>\n288\t                        </DialogHeader>\n289\t                        <div className=\"grid gap-4 py-4\">\n290\t                            <div className=\"grid gap-2\">\n291\t                                <Label htmlFor=\"project-name\">Project Name</Label>\n292\t                                <Input\n293\t                                    id=\"project-name\"\n294\t                                    value={projectForm.data.name}\n295\t                                    onChange={(e) => projectForm.setData('name', e.target.value)}\n296\t                                    placeholder=\"My Project\"\n297\t                                />\n298\t                                <InputError message={projectForm.errors.name} />\n299\t                            </div>\n300\t                            <div className=\"grid gap-2\">\n301\t                                <Label htmlFor=\"project-party\">Client / Party</Label>\n302\t                                <Select\n303\t                                    value={projectForm.data.partyId}\n304\t                                    onValueChange={(value) => projectForm.setData('partyId', value)}\n305\t                                >\n306\t                                    <SelectTrigger>\n307\t                                        <SelectValue placeholder=\"Select a party\" />\n308\t                                    </SelectTrigger>\n309\t                                    <SelectContent>\n310\t                                        {parties.map((party) => (\n311\t                                            <SelectItem key={party.id} value={party.id}>\n312\t                                                {party.name}\n313\t                                            </SelectItem>\n314\t                                        ))}\n315\t                                    </SelectContent>\n316\t                                </Select>\n317\t                                <InputError message={projectForm.errors.partyId} />\n318\t                            </div>\n319\t                            <div className=\"grid gap-2\">\n320\t                                <Label htmlFor=\"project-start-date\">Start Date</Label>\n321\t                                <Input\n322\t                                    id=\"project-start-date\"\n323\t                                    type=\"date\"\n324\t                                    value={projectForm.data.startDate}\n325\t                                    onChange={(e) => projectForm.setData('startDate', e.target.value)}\n326\t                                />\n327\t                                <InputError message={projectForm.errors.startDate} />\n328\t                            </div>\n329\t                            <div className=\"grid gap-2\">\n330\t                                <Label htmlFor=\"project-description\">Description (optional)</Label>\n331\t                                <Input\n332\t                                    id=\"project-description\"\n333\t                                    value={projectForm.data.description}\n334\t                                    onChange={(e) => projectForm.setData('description', e.target.value)}\n335\t                                    placeholder=\"Brief description of the project\"\n336\t                                />\n337\t                                <InputError message={projectForm.errors.description} />\n338\t                            </div>\n339\t                            <div className=\"flex items-center justify-between\">\n340\t                                <div className=\"space-y-0.5\">\n341\t                                    <Label htmlFor=\"project-private\">Private Project</Label>\n342\t                                    <p className=\"text-sm text-muted-foreground\">\n343\t                                        Only you and assigned team members can see this project\n344\t                                    </p>\n345\t                                </div>\n346\t                                <Switch\n347\t                                    id=\"project-private\"\n348\t                                    checked={projectForm.data.isPrivate}\n349\t                                    onCheckedChange={(checked) => projectForm.setData('isPrivate', checked)}\n350\t                                />\n351\t                            </div>\n352\t                        </div>\n353\t                        <DialogFooter>\n354\t                            <Button\n355\t                                type=\"button\"\n356\t                                variant=\"outline\"\n357\t                                onClick={() => setCreateProjectDialogOpen(false)}\n358\t                            >\n359\t                                Cancel\n360\t                            </Button>\n361\t                            <Button type=\"submit\" disabled={projectForm.processing}>\n362\t                                Create Project\n363\t                            </Button>\n364\t                        </DialogFooter>\n365\t                    </form>\n366\t                </DialogContent>\n367\t            </Dialog>\n368\t\n369\t            {/* Create Work Order Dialog */}\n370\t            <Dialog open={createWorkOrderDialogOpen} onOpenChange={setCreateWorkOrderDialogOpen}>\n371\t                <DialogContent>\n372\t                    <form onSubmit={handleSubmitWorkOrder}>\n373\t                        <DialogHeader>\n374\t                            <DialogTitle>Create Work Order</DialogTitle>\n375\t                            <DialogDescription>\n376\t                                Create a new work order to track specific deliverables.\n377\t                            </DialogDescription>\n378\t                        </DialogHeader>\n379\t                        <div className=\"grid gap-4 py-4\">\n380\t                            <div className=\"grid gap-2\">\n381\t                                <Label htmlFor=\"wo-title\">Title</Label>\n382\t                                <Input\n383\t                                    id=\"wo-title\"\n384\t                                    value={workOrderForm.data.title}\n385\t                                    onChange={(e) => workOrderForm.setData('title', e.target.value)}\n386\t                                    placeholder=\"Work order title\"\n387\t                                />\n388\t                                <InputError message={workOrderForm.errors.title} />\n389\t                            </div>\n390\t                            <div className=\"grid gap-2\">\n391\t                                <Label htmlFor=\"wo-project\">Project</Label>\n392\t                                <Select\n393\t                                    value={workOrderForm.data.projectId}\n394\t                                    onValueChange={(value) => workOrderForm.setData('projectId', value)}\n395\t                                >\n396\t                                    <SelectTrigger>\n397\t                                        <SelectValue placeholder=\"Select a project\" />\n398\t                                    </SelectTrigger>\n399\t                                    <SelectContent>\n400\t                                        {projects\n401\t                                            .filter((p) => p.status === 'active' || p.status === 'on_hold')\n402\t                                            .map((project) => (\n403\t                                                <SelectItem key={project.id} value={project.id}>\n404\t                                                    {project.name}\n405\t                                                </SelectItem>\n406\t                                            ))}\n407\t                                    </SelectContent>\n408\t                                </Select>\n409\t                                <InputError message={workOrderForm.errors.projectId} />\n410\t                            </div>\n411\t                            <div className=\"grid gap-2\">\n412\t                                <Label htmlFor=\"wo-priority\">Priority</Label>\n413\t                                <Select\n414\t                                    value={workOrderForm.data.priority}\n415\t                                    onValueChange={(value) =>\n416\t                                        workOrderForm.setData('priority', value as any)\n417\t                                    }\n418\t                                >\n419\t                                    <SelectTrigger>\n420\t                                        <SelectValue />\n421\t                                    </SelectTrigger>\n422\t                                    <SelectContent>\n423\t                                        <SelectItem value=\"low\">Low</SelectItem>\n424\t                                        <SelectItem value=\"medium\">Medium</SelectItem>\n425\t                                        <SelectItem value=\"high\">High</SelectItem>\n426\t                                        <SelectItem value=\"urgent\">Urgent</SelectItem>\n427\t                                    </SelectContent>\n428\t                                </Select>\n429\t                                <InputError message={workOrderForm.errors.priority} />\n430\t                            </div>\n431\t                            <div className=\"grid gap-2\">\n432\t                                <Label htmlFor=\"wo-due-date\">Due Date</Label>\n433\t                                <Input\n434\t                                    id=\"wo-due-date\"\n435\t                                    type=\"date\"\n436\t                                    value={workOrderForm.data.dueDate}\n437\t                                    onChange={(e) => workOrderForm.setData('dueDate', e.target.value)}\n438\t                                />\n439\t                                <InputError message={workOrderForm.errors.dueDate} />\n440\t                            </div>\n441\t                            <div className=\"grid gap-2\">\n442\t                                <Label htmlFor=\"wo-description\">Description (optional)</Label>\n443\t                                <Input\n444\t                                    id=\"wo-description\"\n445\t                                    value={workOrderForm.data.description}\n446\t                                    onChange={(e) => workOrderForm.setData('description', e.target.value)}\n447\t                                    placeholder=\"Brief description\"\n448\t                                />\n449\t                                <InputError message={workOrderForm.errors.description} />\n450\t                            </div>\n451\t                        </div>\n452\t                        <DialogFooter>\n453\t                            <Button\n454\t                                type=\"button\"\n455\t                                variant=\"outline\"\n456\t                                onClick={() => setCreateWorkOrderDialogOpen(false)}\n457\t                            >\n458\t                                Cancel\n459\t                            </Button>\n460\t                            <Button type=\"submit\" disabled={workOrderForm.processing}>\n461\t                                Create Work Order\n462\t                            </Button>\n463\t                        </DialogFooter>\n464\t                    </form>\n465\t                </DialogContent>\n466\t            </Dialog>\n467\t\n468\t            {/* Create Task Dialog */}\n469\t            <Dialog open={createTaskDialogOpen} onOpenChange={setCreateTaskDialogOpen}>\n470\t                <DialogContent>\n471\t                    <form onSubmit={handleSubmitTask}>\n472\t                        <DialogHeader>\n473\t                            <DialogTitle>Create Task</DialogTitle>\n474\t                            <DialogDescription>\n475\t                                Create a new task for tracking individual action items.\n476\t                            </DialogDescription>\n477\t                        </DialogHeader>\n478\t                        <div className=\"grid gap-4 py-4\">\n479\t                            <div className=\"grid gap-2\">\n480\t                                <Label htmlFor=\"task-title\">Title</Label>\n481\t                                <Input\n482\t                                    id=\"task-title\"\n483\t                                    value={taskForm.data.title}\n484\t                                    onChange={(e) => taskForm.setData('title', e.target.value)}\n485\t                                    placeholder=\"Task title\"\n486\t                                />\n487\t                                <InputError message={taskForm.errors.title} />\n488\t                            </div>\n489\t                            <div className=\"grid gap-2\">\n490\t                                <Label htmlFor=\"task-wo\">Work Order</Label>\n491\t                                <Select\n492\t                                    value={taskForm.data.workOrderId}\n493\t                                    onValueChange={(value) => taskForm.setData('workOrderId', value)}\n494\t                                >\n495\t                                    <SelectTrigger>\n496\t                                        <SelectValue placeholder=\"Select a work order\" />\n497\t                                    </SelectTrigger>\n498\t                                    <SelectContent>\n499\t                                        {workOrders\n500\t                                            .filter((wo) => wo.status !== 'delivered')\n501\t                                            .map((wo) => (\n502\t                                                <SelectItem key={wo.id} value={wo.id}>\n503\t                                                    {wo.title}\n504\t                                                </SelectItem>\n505\t                                            ))}\n506\t                                    </SelectContent>\n507\t                                </Select>\n508\t                                <InputError message={taskForm.errors.workOrderId} />\n509\t                            </div>\n510\t                            <div className=\"grid gap-2\">\n511\t                                <Label htmlFor=\"task-due-date\">Due Date</Label>\n512\t                                <Input\n513\t                                    id=\"task-due-date\"\n514\t                                    type=\"date\"\n515\t                                    value={taskForm.data.dueDate}\n516\t                                    onChange={(e) => taskForm.setData('dueDate', e.target.value)}\n517\t                                />\n518\t                                <InputError message={taskForm.errors.dueDate} />\n519\t                            </div>\n520\t                            <div className=\"grid gap-2\">\n521\t                                <Label htmlFor=\"task-description\">Description (optional)</Label>\n522\t                                <Input\n523\t                                    id=\"task-description\"\n524\t                                    value={taskForm.data.description}\n525\t                                    onChange={(e) => taskForm.setData('description', e.target.value)}\n526\t                                    placeholder=\"Brief description\"\n527\t                                />\n528\t                                <InputError message={taskForm.errors.description} />\n529\t                            </div>\n530\t                        </div>\n531\t                        <DialogFooter>\n532\t                            <Button\n533\t                                type=\"button\"\n534\t                                variant=\"outline\"\n535\t                                onClick={() => setCreateTaskDialogOpen(false)}\n536\t                            >\n537\t                                Cancel\n538\t                            </Button>\n539\t                            <Button type=\"submit\" disabled={taskForm.processing}>\n540\t                                Create Task\n541\t                            </Button>\n542\t                        </DialogFooter>\n543\t                    </form>\n544\t                </DialogContent>\n545\t            </Dialog>\n546\t        </AppLayout>\n547\t    );\n548\t}\n549\t"}}
{"run_id": "456655ffe7c3", "timestamp": "2026-05-08T18:07:51Z", "type": "adapter.tool_result", "agent": "pm", "data": {"message": "1\t<?php\n2\t\n3\tdeclare(strict_types=1);\n4\t\n5\tnamespace App\\Models;\n6\t\n7\tuse App\\Enums\\BudgetType;\n8\tuse App\\Enums\\PMCopilotMode;\n9\tuse App\\Enums\\Priority;\n10\tuse App\\Enums\\WorkOrderStatus;\n11\tuse Illuminate\\Database\\Eloquent\\Builder;\n12\tuse Illuminate\\Database\\Eloquent\\Casts\\Attribute;\n13\tuse Illuminate\\Database\\Eloquent\\Factories\\HasFactory;\n14\tuse Illuminate\\Database\\Eloquent\\Model;\n15\tuse Illuminate\\Database\\Eloquent\\Relations\\BelongsTo;\n16\tuse Illuminate\\Database\\Eloquent\\Relations\\HasMany;\n17...", "tool_use_id": "toolu_01Pn33qnD8B1DBpt27Pf1KGB", "is_error": false, "full_result": "1\t<?php\n2\t\n3\tdeclare(strict_types=1);\n4\t\n5\tnamespace App\\Models;\n6\t\n7\tuse App\\Enums\\BudgetType;\n8\tuse App\\Enums\\PMCopilotMode;\n9\tuse App\\Enums\\Priority;\n10\tuse App\\Enums\\WorkOrderStatus;\n11\tuse Illuminate\\Database\\Eloquent\\Builder;\n12\tuse Illuminate\\Database\\Eloquent\\Casts\\Attribute;\n13\tuse Illuminate\\Database\\Eloquent\\Factories\\HasFactory;\n14\tuse Illuminate\\Database\\Eloquent\\Model;\n15\tuse Illuminate\\Database\\Eloquent\\Relations\\BelongsTo;\n16\tuse Illuminate\\Database\\Eloquent\\Relations\\HasMany;\n17\tuse Illuminate\\Database\\Eloquent\\Relations\\MorphMany;\n18\tuse Illuminate\\Database\\Eloquent\\Relations\\MorphOne;\n19\tuse Illuminate\\Database\\Eloquent\\SoftDeletes;\n20\t\n21\tclass WorkOrder extends Model\n22\t{\n23\t    use HasFactory, SoftDeletes;\n24\t\n25\t    protected $fillable = [\n26\t        'team_id',\n27\t        'project_id',\n28\t        'work_order_list_id',\n29\t        'position_in_list',\n30\t        'assigned_to_id',\n31\t        'created_by_id',\n32\t        'accountable_id',\n33\t        'responsible_id',\n34\t        'reviewer_id',\n35\t        'consulted_ids',\n36\t        'informed_ids',\n37\t        'party_contact_id',\n38\t        'title',\n39\t        'description',\n40\t        'status',\n41\t        'priority',\n42\t        'due_date',\n43\t        'estimated_hours',\n44\t        'budget_type',\n45\t        'budget_cost',\n46\t        'actual_hours',\n47\t        'actual_cost',\n48\t        'actual_revenue',\n49\t        'acceptance_criteria',\n50\t        'sop_attached',\n51\t        'sop_name',\n52\t        'pm_copilot_mode',\n53\t    ];\n54\t\n55\t    protected $casts = [\n56\t        'status' => WorkOrderStatus::class,\n57\t        'priority' => Priority::class,\n58\t        'budget_type' => BudgetType::class,\n59\t        'due_date' => 'date',\n60\t        'estimated_hours' => 'decimal:2',\n61\t        'budget_cost' => 'decimal:2',\n62\t        'actual_hours' => 'decimal:2',\n63\t        'actual_cost' => 'decimal:2',\n64\t        'actual_revenue' => 'decimal:2',\n65\t        'acceptance_criteria' => 'array',\n66\t        'sop_attached' => 'boolean',\n67\t        'consulted_ids' => 'array',\n68\t        'informed_ids' => 'array',\n69\t        'position_in_list' => 'integer',\n70\t    ];\n71\t\n72\t    public function team(): BelongsTo\n73\t    {\n74\t        return $this->belongsTo(Team::class);\n75\t    }\n76\t\n77\t    public function project(): BelongsTo\n78\t    {\n79\t        return $this->belongsTo(Project::class);\n80\t    }\n81\t\n82\t    public function workOrderList(): BelongsTo\n83\t    {\n84\t        return $this->belongsTo(WorkOrderList::class);\n85\t    }\n86\t\n87\t    public function assignedTo(): BelongsTo\n88\t    {\n89\t        return $this->belongsTo(User::class, 'assigned_to_id');\n90\t    }\n91\t\n92\t    public function createdBy(): BelongsTo\n93\t    {\n94\t        return $this->belongsTo(User::class, 'created_by_id');\n95\t    }\n96\t\n97\t    /**\n98\t     * Get the user who is accountable for this work order.\n99\t     */\n100\t    public function accountable(): BelongsTo\n101\t    {\n102\t        return $this->belongsTo(User::class, 'accountable_id');\n103\t    }\n104\t\n105\t    /**\n106\t     * Get the user who is responsible for this work order.\n107\t     */\n108\t    public function responsible(): BelongsTo\n109\t    {\n110\t        return $this->belongsTo(User::class, 'responsible_id');\n111\t    }\n112\t\n113\t    /**\n114\t     * Get the user who is the explicit reviewer for this work order.\n115\t     */\n116\t    public function reviewer(): BelongsTo\n117\t    {\n118\t        return $this->belongsTo(User::class, 'reviewer_id');\n119\t    }\n120\t\n121\t    public function partyContact(): BelongsTo\n122\t    {\n123\t        return $this->belongsTo(Party::class, 'party_contact_id');\n124\t    }\n125\t\n126\t    public function tasks(): HasMany\n127\t    {\n128\t        return $this->hasMany(Task::class);\n129\t    }\n130\t\n131\t    public function deliverables(): HasMany\n132\t    {\n133\t        return $this->hasMany(Deliverable::class);\n134\t    }\n135\t\n136\t    public function communicationThread(): MorphOne\n137\t    {\n138\t        return $this->morphOne(CommunicationThread::class, 'threadable');\n139\t    }\n140\t\n141\t    public function documents(): MorphMany\n142\t    {\n143\t        return $this->morphMany(Document::class, 'documentable');\n144\t    }\n145\t\n146\t    /**\n147\t     * Get all status transitions for this work order.\n148\t     */\n149\t    public function statusTransitions(): MorphMany\n150\t    {\n151\t        return $this->morphMany(StatusTransition::class, 'transitionable')\n152\t            ->orderByDesc('created_at');\n153\t    }\n154\t\n155\t    /**\n156\t     * Get the PM Copilot mode for this work order.\n157\t     *\n158\t     * Returns the configured mode or defaults to 'full' if not set.\n159\t     */\n160\t    protected function pmCopilotMode(): Attribute\n161\t    {\n162\t        return Attribute::make(\n163\t            get: fn (?string $value) => $value\n164\t                ? PMCopilotMode::from($value)\n165\t                : PMCopilotMode::Full,\n166\t            set: fn (PMCopilotMode|string|null $value) => $value instanceof PMCopilotMode\n167\t                ? $value->value\n168\t                : $value,\n169\t        );\n170\t    }\n171\t\n172\t    /**\n173\t     * Check if PM Copilot is in staged mode for this work order.\n174\t     */\n175\t    public function isPMCopilotStagedMode(): bool\n176\t    {\n177\t        return $this->pm_copilot_mode === PMCopilotMode::Staged;\n178\t    }\n179\t\n180\t    /**\n181\t     * Check if PM Copilot is in full mode for this work order.\n182\t     */\n183\t    public function isPMCopilotFullMode(): bool\n184\t    {\n185\t        return $this->pm_copilot_mode === PMCopilotMode::Full;\n186\t    }\n187\t\n188\t    public function scopeForTeam(Builder $query, int $teamId): Builder\n189\t    {\n190\t        return $query->where('team_id', $teamId);\n191\t    }\n192\t\n193\t    public function scopeAssignedTo(Builder $query, int $userId): Builder\n194\t    {\n195\t        return $query->where('assigned_to_id', $userId);\n196\t    }\n197\t\n198\t    public function scopeWithStatus(Builder $query, WorkOrderStatus $status): Builder\n199\t    {\n200\t        return $query->where('status', $status);\n201\t    }\n202\t\n203\t    public function scopeArchived(Builder $query): Builder\n204\t    {\n205\t        return $query->where('status', WorkOrderStatus::Archived);\n206\t    }\n207\t\n208\t    public function scopeNotArchived(Builder $query): Builder\n209\t    {\n210\t        return $query->where('status', '!=', WorkOrderStatus::Archived);\n211\t    }\n212\t\n213\t    public function scopeInList(Builder $query, ?int $listId): Builder\n214\t    {\n215\t        return $query->where('work_order_list_id', $listId);\n216\t    }\n217\t\n218\t    public function scopeOrderedInList(Builder $query): Builder\n219\t    {\n220\t        return $query->orderBy('position_in_list');\n221\t    }\n222\t\n223\t    public function scopeUngrouped(Builder $query): Builder\n224\t    {\n225\t        return $query->whereNull('work_order_list_id');\n226\t    }\n227\t\n228\t    /**\n229\t     * Scope to filter work orders where the user has any RACI role.\n230\t     */\n231\t    public function scopeWhereUserHasRaciRole(Builder $query, int $userId, bool $excludeInformed = true): Builder\n232\t    {\n233\t        return $query->where(function (Builder $q) use ($userId, $excludeInformed) {\n234\t            $q->where('accountable_id', $userId)\n235\t                ->orWhere('responsible_id', $userId)\n236\t                ->orWhereJsonContains('consulted_ids', $userId);\n237\t\n238\t            if (! $excludeInformed) {\n239\t                $q->orWhereJsonContains('informed_ids', $userId);\n240\t            }\n241\t        });\n242\t    }\n243\t\n244\t    /**\n245\t     * Scope to filter work orders where the user is accountable.\n246\t     */\n247\t    public function scopeWhereUserIsAccountable(Builder $query, int $userId): Builder\n248\t    {\n249\t        return $query->where('accountable_id', $userId);\n250\t    }\n251\t\n252\t    /**\n253\t     * Scope to filter work orders where the user is responsible.\n254\t     */\n255\t    public function scopeWhereUserIsResponsible(Builder $query, int $userId): Builder\n256\t    {\n257\t        return $query->where('responsible_id', $userId);\n258\t    }\n259\t\n260\t    /**\n261\t     * Scope to filter work orders in review status where the user is accountable.\n262\t     */\n263\t    public function scopeInReviewWhereUserIsAccountable(Builder $query, int $userId): Builder\n264\t    {\n265\t        return $query->where('status', WorkOrderStatus::InReview)\n266\t            ->where('accountable_id', $userId);\n267\t    }\n268\t\n269\t    /**\n270\t     * Get the RACI roles the given user has for this work order.\n271\t     *\n272\t     * @return array<string>\n273\t     */\n274\t    public function getUserRaciRoles(int $userId): array\n275\t    {\n276\t        $roles = [];\n277\t\n278\t        if ($this->accountable_id === $userId) {\n279\t            $roles[] = 'accountable';\n280\t        }\n281\t\n282\t        if ($this->responsible_id === $userId) {\n283\t            $roles[] = 'responsible';\n284\t        }\n285\t\n286\t        if (is_array($this->consulted_ids) && in_array($userId, $this->consulted_ids, true)) {\n287\t            $roles[] = 'consulted';\n288\t        }\n289\t\n290\t        if (is_array($this->informed_ids) && in_array($userId, $this->informed_ids, true)) {\n291\t            $roles[] = 'informed';\n292\t        }\n293\t\n294\t        return $roles;\n295\t    }\n296\t\n297\t    public function getTasksCountAttribute(): int\n298\t    {\n299\t        return $this->tasks()->count();\n300\t    }\n301\t\n302\t    public function getCompletedTasksCountAttribute(): int\n303\t    {\n304\t        return $this->tasks()->where('status', 'done')->count();\n305\t    }\n306\t\n307\t    public function recalculateActualHours(): void\n308\t    {\n309\t        $this->actual_hours = $this->tasks()->sum('actual_hours');\n310\t        $this->save();\n311\t\n312\t        // Also recalculate costs\n313\t        $this->recalculateActualCost();\n314\t    }\n315\t\n316\t    /**\n317\t     * Recalculate actual cost and revenue from tasks.\n318\t     *\n319\t     * Sums actual_cost and actual_revenue from all tasks\n320\t     * and bubbles up to parent project.\n321\t     */\n322\t    public function recalculateActualCost(): void\n323\t    {\n324\t        $this->actual_cost = $this->tasks()->sum('actual_cost');\n325\t        $this->actual_revenue = $this->tasks()->sum('actual_revenue');\n326\t        $this->save();\n327\t\n328\t        // Bubble up to parent project\n329\t        $this->project->recalculateActualCost();\n330\t    }\n331\t}\n332\t"}}
