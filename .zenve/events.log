d-900 dark:text-red-300';\n33\t            }\n34\t            if (wo.priority === 'high') {\n35\t                return 'bg-orange-50 dark:bg-orange-950/20 border-orange-200 dark:border-orange-900 text-orange-900 dark:text-orange-300';\n36\t            }\n37\t            if (wo.status === 'in_review') {\n38\t                return 'bg-amber-50 dark:bg-amber-950/20 border-amber-200 dark:border-amber-900 text-amber-900 dark:text-amber-300';\n39\t            }\n40\t            if (wo.status === 'delivered') {\n41\t                return 'bg-muted border-border text-muted-foreground';\n42\t            }\n43\t        }\n44\t\n45\t        if (isProject) {\n46\t            return 'bg-indigo-50 dark:bg-indigo-950/20 border-indigo-200 dark:border-indigo-900 text-indigo-900 dark:text-indigo-300';\n47\t        }\n48\t\n49\t        return 'bg-emerald-50 dark:bg-emerald-950/20 border-emerald-200 dark:border-emerald-900 text-emerald-900 dark:text-emerald-300';\n50\t    };\n51\t\n52\t    const title = isProject ? (item as Project).name : (item as WorkOrder).title;\n53\t    const status = isProject ? (item as Project).status : (item as WorkOrder).status;\n54\t\n55\t    const href = isProject ? `/work/projects/${item.id}` : `/work/work-orders/${item.id}`;\n56\t\n57\t    return (\n58\t        <Link\n59\t            href={href}\n60\t            className={`block w-full text-left px-2 py-1 mb-1 rounded border text-xs font-medium transition-all hover:scale-[1.02] hover:shadow-sm ${getColorClasses()}`}\n61\t        >\n62\t            <div className=\"flex items-start gap-1\">\n63\t                {isOverdue && <AlertCircle className=\"w-3 h-3 shrink-0 mt-0.5\" />}\n64\t                <div className=\"flex-1 min-w-0\">\n65\t                    <div className=\"truncate font-semibold\">{title}</div>\n66\t                    <div className=\"flex items-center gap-1 mt-0.5 opacity-75\">\n67\t                        <Clock className=\"w-2.5 h-2.5\" />\n68\t                        <span className=\"text-[10px] uppercase tracking-wide\">\n69\t                            {status.replace('_', ' ')}\n70\t                        </span>\n71\t                        {priority && (\n72\t                            <>\n73\t                                <span className=\"text-[8px]\">\u2022</span>\n74\t                                <span className=\"text-[10px] uppercase tracking-wide\">{priority}</span>\n75\t                            </>\n76\t                        )}\n77\t                    </div>\n78\t                </div>\n79\t            </div>\n80\t        </Link>\n81\t    );\n82\t}\n83\t"}}
